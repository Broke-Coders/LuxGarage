{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "LuxGarage.API/**/*.csproj",
          ]
        }
      ],
      "dest": "API"
    },
	 {
      "src": [
        {
          "src": ".",
          "files": [
			"LuxGarage.Tests/**/*.csproj"
          ]
        }
      ],
      "dest": "Tests"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "mysite",
      "_appTitle": "mysite",
      "_enableSearch": true
    }
  }
}